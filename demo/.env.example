# Aztec Alpha testnet PXE endpoint.
# Either run a local PXE (`aztec start --pxe nodeUrl=https://rpc.testnet.aztec-labs.com`)
# and point this at it, or use a hosted PXE for the testnet.
NEXT_PUBLIC_AZTEC_PXE_URL=http://localhost:8080

# The Aztec Alpha testnet node URL. Used by PXE; included for reference.
NEXT_PUBLIC_AZTEC_NODE_URL=https://rpc.testnet.aztec-labs.com

# Address of a deployed PrivateVoting contract on Aztec Alpha testnet.
NEXT_PUBLIC_VOTE_CONTRACT_ADDRESS=0x...
